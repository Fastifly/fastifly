{
  "name": "@fastifly/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "typecheck:tests": "tsgo -p tsconfig.tests.json --noEmit",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e/**/*.e2e.test.ts",
    "test:e2e:postgres": "vitest run tests/e2e/workflows/postgres-runtime-parity.e2e.test.ts",
    "test:unit": "vitest run src/__tests__/**/*.test.ts"
  },
  "dependencies": {
    "@fastifly/authz": "workspace:*",
    "@fastifly/common": "workspace:*",
    "@fastifly/config": "workspace:*",
    "@fastifly/db": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@node-rs/argon2": "^2.0.2",
    "@scalar/fastify-api-reference": "^1.55.3",
    "@simplewebauthn/server": "^13.3.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "tsx": "^4.21.0",
    "typescript": "latest"
  }
}
