{
  "name": "@fastifly/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "test:sqlite": "vitest run src/__tests__/sqlite-migrations.test.ts",
    "test:postgres": "vitest run src/__tests__/postgres-migrations.test.ts",
    "test:postgres:runtime": "vitest run src/__tests__/postgres-js-runtime.test.ts",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:generate:postgres": "drizzle-kit generate --config=drizzle.postgres.config.ts",
    "db:migrate:sqlite": "node -e \"if (!process.env.DATABASE_URL) { console.error('DATABASE_URL is required for SQLite migrations.'); process.exit(1); }\" && drizzle-kit migrate --config=drizzle.sqlite.config.ts",
    "db:migrate:postgres": "node -e \"if (!process.env.DATABASE_URL) { console.error('DATABASE_URL is required for PostgreSQL migrations.'); process.exit(1); }\" && drizzle-kit migrate --config=drizzle.postgres.config.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@fastifly/common": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "1.0.0-rc.2",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.3",
    "drizzle-kit": "1.0.0-rc.2",
    "typescript": "latest"
  }
}
