{
  "name": "fastifly",
  "private": true,
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
  "scripts": {
    "start": "node scripts/start.mjs",
    "dev": "pnpm start",
    "dev:sqlite": "FASTIFLY_DEV_DB=sqlite FASTIFLY_DEV_SEED=none node scripts/start.mjs",
    "dev:sqlite:demo": "FASTIFLY_DEV_DB=sqlite FASTIFLY_DEV_SEED=e2e node scripts/start.mjs",
    "dev:postgres": "FASTIFLY_DEV_DB=postgres FASTIFLY_DEV_SEED=none node scripts/start.mjs",
    "dev:postgres:demo": "FASTIFLY_DEV_DB=postgres FASTIFLY_DEV_SEED=e2e node scripts/start.mjs",
    "dev:postgres:down": "docker compose -f docker-compose.dev-postgres.yml down",
    "build": "turbo run build",
    "api:generate": "pnpm --filter @fastifly/api exec node --import tsx ../../scripts/generate-openapi.mjs && pnpm exec biome format --write apps/web/src/api/generated/openapi.ts",
    "api:check": "pnpm api:generate && git diff --exit-code -- apps/web/src/api/generated/openapi.ts",
    "check:testids": "node scripts/check-testid-literals.mjs",
    "typecheck": "turbo run typecheck",
    "typecheck:refs": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint:packages": "turbo run lint",
    "test": "turbo run test",
    "test:api:e2e": "pnpm --filter @fastifly/api run test:e2e",
    "test:api:e2e:postgres": "pnpm --filter @fastifly/api run test:e2e:postgres",
    "test:sqlite": "pnpm --filter @fastifly/db test:sqlite",
    "test:postgres:pglite": "pnpm --filter @fastifly/db test:postgres:pglite",
    "test:postgres": "pnpm --filter @fastifly/db test:postgres",
    "test:postgres:runtime": "pnpm --filter @fastifly/db test:postgres:runtime",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm typecheck:tsc && pnpm typecheck:refs && pnpm api:check && pnpm test && pnpm test:sqlite && pnpm test:postgres",
    "typecheck:tsc": "turbo run typecheck:tsc",
    "db:generate:sqlite": "pnpm --filter @fastifly/db db:generate:sqlite",
    "db:generate:postgres": "pnpm --filter @fastifly/db db:generate:postgres",
    "db:migrate:sqlite": "pnpm --filter @fastifly/db db:migrate:sqlite",
    "db:migrate:postgres": "pnpm --filter @fastifly/db db:migrate:postgres",
    "logs": "tilt logs --port 10360 --follow",
    "logs:api": "tilt logs --port 10360 --source runtime --follow api",
    "logs:api:error": "tilt logs --port 10360 --source runtime --level error --follow api",
    "db:clean": "tilt trigger db-clean --port 10360",
    "db:seed": "tilt trigger db-seed --port 10360",
    "db:seed:essential": "pnpm --filter @fastifly/db build && pnpm --filter @fastifly/db db:seed:essential",
    "db:seed:demo": "pnpm --filter @fastifly/db build && pnpm --filter @fastifly/db db:seed:demo",
    "db:seed:e2e": "pnpm --filter @fastifly/db build && pnpm --filter @fastifly/db db:seed:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@typescript/native-preview": "latest",
    "openapi-typescript": "^7.13.0",
    "turbo": "latest",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
